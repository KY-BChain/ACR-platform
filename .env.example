# ACR Platform Environment Variables

# API Gateway
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://acr_user:changeme@localhost:5432/acr_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production

# CORS
CORS_ORIGIN=*

# IPFS
IPFS_URL=http://localhost:5001

# RSK Blockchain
RSK_RPC_URL=https://public-node.testnet.rsk.co
RSK_CHAIN_ID=31

# Smart Contract Addresses (update after deployment)
IDENTITY_REGISTRY_ADDRESS=
MODEL_REGISTRY_ADDRESS=
SWRL_DAO_ADDRESS=
ACR_GOV_TOKEN_ADDRESS=
ACR_RWA_TOKEN_ADDRESS=

# Private Key (for contract deployment)
PRIVATE_KEY=

# Ontology
ONTOLOGY_PATH=./acr-ontology/ACR.owl

# Python Agents
PYTHONUNBUFFERED=1

# Differential Privacy
DP_EPSILON=0.7
DP_DELTA=0.000001
