                 rdfs:label "样本类型和样本ID"@zh .


acr:has残余病灶状态 rdfs:comment "新辅助治疗后残余病灶状态摘要，如残余浸润癌/仅原位癌/无残余"@zh ;
              rdfs:label "残余病灶状态"@zh .


acr:has治疗期间不良事件 rdfs:comment "重大不良事件和CTCAE等级（如可用）"@zh ;
                rdfs:label "治疗期间不良事件"@zh .


acr:has活检建议 rdfs:comment "结构化活检建议，如粗针穿刺活检、真空辅助活检、短期随访"@zh ;
            rdfs:label "活检建议"@zh .


acr:has活检影像引导 rdfs:comment "用于引导活检的影像（超声、立体定位、MRI）"@zh ;
              rdfs:label "活检影像引导"@zh .


acr:has活检技术 rdfs:comment "空心针穿刺/FNA/切除等"@zh ;
            rdfs:label "活检技术"@zh .


acr:has活检日期Or时间 rdfs:comment "活检程序日期和时间"@zh ;
                rdfs:label "活检日期/时间"@zh .


acr:has活检时放置标记夹 rdfs:comment "是否放置标记夹（是/否）"@zh ;
                rdfs:label "活检时放置标记夹"@zh .


acr:has活检标本标识符 rdfs:comment "活检病理标本ID"@zh ;
               rdfs:label "活检标本标识符"@zh .


acr:has淋巴结阳性个数 rdfs:comment "术后病理明确的阳性淋巴结个数"@zh ;
               rdfs:label "淋巴结阳性个数"@zh .


acr:has淋巴血管侵犯 rdfs:comment "存在/缺失"@zh ;
              rdfs:label "淋巴血管侵犯"@zh .


acr:has病理TNMpTNM rdfs:comment "术后病理T、N、M组分（pT、pN、pM）"@zh ;
                 rdfs:label "病理TNM（pTNM）"@zh .


acr:has病理完全缓解pCR rdfs:comment "新辅助治疗后是否达到病理完全缓解"@zh ;
                 rdfs:label "病理完全缓解pCR"@zh .


acr:has病理报告完整文本 rdfs:comment "完整病理叙述"@zh ;
                rdfs:label "病理报告完整文本"@zh .


acr:has病理报告日期 rdfs:comment "病理报告定稿日期"@zh ;
              rdfs:label "病理报告日期"@zh .


acr:has病理诊断简短文本 rdfs:comment "诊断短语（例如，浸润性导管癌）"@zh ;
                rdfs:label "病理诊断简短文本"@zh .


acr:has神经周围侵犯 rdfs:comment "存在/缺失"@zh ;
              rdfs:label "神经周围侵犯"@zh .


acr:has籍贯户口 rdfs:comment "患者籍贯"@zh ;
            rdfs:label "籍贯（户口）"@zh .


acr:has组织学亚型详细 rdfs:comment "详细组织学亚型"@zh ;
               rdfs:label "组织学亚型（详细）"@zh .


acr:has组织学分级 rdfs:comment "1、2或3级"@zh ;
             rdfs:label "组织学分级"@zh .


acr:has肿瘤多灶性 rdfs:comment "影像或病理提示单灶/多灶/多中心"@zh ;
             rdfs:label "肿瘤多灶性"@zh .


acr:has肿瘤大小最大毫米 rdfs:comment "肿瘤最大尺寸（毫米）"@zh ;
                rdfs:label "肿瘤大小（最大毫米）"@zh .


acr:has肿瘤标志物随访 rdfs:comment "系列肿瘤标志物值和检测日期"@zh ;
               rdfs:label "肿瘤标志物随访"@zh .


acr:has肿瘤标志物：CA15-3OrCEAOrCA125 rdfs:comment "结果含单位和异常标志"@zh ;
                                rdfs:label "肿瘤标志物：CA15-3 / CEA / CA125"@zh .


acr:has胚系BRCA状态 rdfs:comment "BRCA1/2致病性/VUS/阴性（如检测）"@zh ;
                rdfs:label "胚系BRCA状态"@zh .


acr:has腋窝管理 rdfs:comment "前哨淋巴结活检或腋窝清扫"@zh ;
            rdfs:label "腋窝管理"@zh .


acr:has计划Or执行的手术类型和日期 rdfs:comment "乳腺手术类型和执行日期"@zh ;
                      rdfs:label "计划/执行的手术类型和日期"@zh .


acr:has计划程序开始Or结束和执行医生 rdfs:comment "计划日期和执行医生"@zh ;
                       rdfs:label "计划程序开始/结束和执行医生"@zh .


acr:has负责联系人站点 rdfs:comment "站点确认此字段的负责姓名或角色"@zh ;
               rdfs:label "负责联系人（站点）"@zh .


acr:has身高厘米 rdfs:comment "身高（厘米）"@zh ;
            rdfs:label "身高（厘米）"@zh .


acr:has转移治疗线别 rdfs:comment "转移性乳腺癌治疗线别，如一线、二线、三线及以上"@zh ;
              rdfs:label "转移治疗线别"@zh .


acr:has转诊医生角色 rdfs:comment "转诊医生角色（全科医生、乳腺外科医生、放射科医生）"@zh ;
              rdfs:label "转诊医生角色"@zh .


acr:has远处转移部位 rdfs:comment "远处转移部位列表，例如骨、肝、肺、脑"@zh ;
              rdfs:label "远处转移部位"@zh .


acr:has遗传咨询建议 rdfs:comment "是否建议遗传咨询/检测及其理由"@zh ;
              rdfs:label "遗传咨询建议"@zh .


acr:has铂类适应证 rdfs:comment "铂类化疗适应证摘要，常用于部分TNBC/BRCA相关情景"@zh ;
             rdfs:label "铂类适应证"@zh .


acr:has随访计划 rdfs:comment "计划随访间隔和影像"@zh ;
            rdfs:label "随访计划"@zh .


