@prefix : <https://medical-ai.org/ontologies/ACR#> .
@prefix acr: <https://medical-ai.org/ontologies/ACR#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://medical-ai.org/ontologies/ACR#> .

[ rdf:type owl:Ontology ;
   rdfs:comment ""
 ] .

#################################################################
#    Object Properties
#################################################################

###  https://medical-ai.org/ontologies/ACR#applicableToCancerType
acr:applicableToCancerType rdf:type owl:ObjectProperty ;
                           rdfs:domain acr:GuidelineRecommendation ;
                           rdfs:range acr:CancerType ;
                           rdfs:label "applicable to cancer type"@en ,
                                      "适用癌症类型"@zh .


###  https://medical-ai.org/ontologies/ACR#hasGuidelineSource
acr:hasGuidelineSource rdf:type owl:ObjectProperty ;
                       rdfs:domain acr:GuidelineRecommendation ;
                       rdfs:range acr:GuidelineOrganization ;
                       rdfs:label "has guideline source"@en ,
                                  "指南来源"@zh .


###  https://medical-ai.org/ontologies/ACR#hasRecommendationLevel
acr:hasRecommendationLevel rdf:type owl:ObjectProperty ;
                           rdfs:domain acr:GuidelineRecommendation ;
                           rdfs:range acr:RecommendationLevel ;
                           rdfs:label "has recommendation level"@en ,
                                      "推荐等级"@zh .


###  https://medical-ai.org/ontologies/ACR#recommendsTreatment
acr:recommendsTreatment rdf:type owl:ObjectProperty ;
                        rdfs:domain acr:GuidelineRecommendation ;
                        rdfs:range acr:TreatmentPlan ;
                        rdfs:label "recommends treatment"@en ,
                                   "推荐治疗方案"@zh .


###  https://medical-ai.org/ontologies/ACR#requiresBiomarker
acr:requiresBiomarker rdf:type owl:ObjectProperty ;
                      rdfs:domain acr:GuidelineRecommendation ;
                      rdfs:range acr:Biomarker ;
                      rdfs:label "requires biomarker"@en ,
                                 "需要生物标志物"@zh .


