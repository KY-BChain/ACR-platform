[ rdfs:label "R4" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> acr:Patient ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#p>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> acr:hasER结果标志和百分比 ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#p> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#er>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> acr:hasPR结果标志和百分比 ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#p> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#pr>
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#propertyPredicate> acr:hasHER2最终解释 ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#p> ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument2> "阳性"
                                                                                      ] ;
                                                                            rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                       rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#BuiltinAtom> ;
                                                                                                   <http://www.w3.org/2003/11/swrl#builtin> <http://www.w3.org/2003/11/swrlb#equal> ;
                                                                                                   <http://www.w3.org/2003/11/swrl#arguments> [ rdf:type rdf:List ;
                                                                                                                                                rdf:first <urn:swrl:var#er> ;
                                                                                                                                                rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                           rdf:first 0 ;
                                                                                                                                                           rdf:rest rdf:nil
                                                                                                                                                         ]
                                                                                                                                              ]
                                                                                                 ] ;
                                                                                       rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                  rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#BuiltinAtom> ;
                                                                                                              <http://www.w3.org/2003/11/swrl#builtin> <http://www.w3.org/2003/11/swrlb#equal> ;
                                                                                                              <http://www.w3.org/2003/11/swrl#arguments> [ rdf:type rdf:List ;
                                                                                                                                                           rdf:first <urn:swrl:var#pr> ;
                                                                                                                                                           rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                                      rdf:first 0 ;
                                                                                                                                                                      rdf:rest rdf:nil
                                                                                                                                                                    ]
                                                                                                                                                         ]
                                                                                                            ] ;
                                                                                                  rdf:rest rdf:nil
                                                                                                ]
                                                                                     ]
                                                                          ]
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> acr:hasMolecularSubtype ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#p> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> "HER2Enriched"
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:label "R1" ;
