    <DLSafeRule>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>R23</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class abbreviatedIRI="acr:Patient"/>
                <Variable IRI="urn:swrl:var#p"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has年龄推导"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Variable IRI="urn:swrl:var#age"/>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#lessThan">
                <Variable IRI="urn:swrl:var#age"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#integer">40</Literal>
            </BuiltInAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has家族癌症史"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Variable IRI="urn:swrl:var#familyHx"/>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#contains">
                <Variable IRI="urn:swrl:var#familyHx"/>
                <Literal>乳腺癌</Literal>
            </BuiltInAtom>
        </Body>
        <Head>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:requiresMDT"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:recommendsGeneticTesting"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:mdtReason"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal>年轻患者伴家族史，需遗传咨询和MDT讨论</Literal>
            </DataPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>R43</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class abbreviatedIRI="acr:Patient"/>
                <Variable IRI="urn:swrl:var#p"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has年龄推导"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Variable IRI="urn:swrl:var#age"/>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#lessThan">
                <Variable IRI="urn:swrl:var#age"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#integer">50</Literal>
            </BuiltInAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has家族癌症史"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Variable IRI="urn:swrl:var#fhx"/>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#contains">
                <Variable IRI="urn:swrl:var#fhx"/>
                <Literal>乳腺癌</Literal>
            </BuiltInAtom>
        </Body>
        <Head>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:recommendsGeneticTesting"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has遗传咨询建议"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal>建议胚系遗传咨询及BRCA检测</Literal>
            </DataPropertyAtom>
        </Head>
    </DLSafeRule>
    <DLSafeRule>
        <Annotation>
            <AnnotationProperty abbreviatedIRI="rdfs:label"/>
            <Literal>R36</Literal>
        </Annotation>
        <Body>
            <ClassAtom>
                <Class abbreviatedIRI="acr:Patient"/>
                <Variable IRI="urn:swrl:var#p"/>
            </ClassAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has活检日期Or时间"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Variable IRI="urn:swrl:var#biopsyDate"/>
            </DataPropertyAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:has全身治疗开始日期"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Variable IRI="urn:swrl:var#treatmentStart"/>
            </DataPropertyAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#subtractDateTimes">
                <Variable IRI="urn:swrl:var#treatmentStart"/>
                <Variable IRI="urn:swrl:var#biopsyDate"/>
                <Variable IRI="urn:swrl:var#days"/>
            </BuiltInAtom>
            <BuiltInAtom IRI="http://www.w3.org/2003/11/swrlb#greaterThan">
                <Variable IRI="urn:swrl:var#days"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#integer">60</Literal>
            </BuiltInAtom>
        </Body>
        <Head>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:timelinessDeviation"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#boolean">true</Literal>
            </DataPropertyAtom>
            <DataPropertyAtom>
                <DataProperty abbreviatedIRI="acr:deviationMessage"/>
                <Variable IRI="urn:swrl:var#p"/>
                <Literal>诊断到治疗超过60天</Literal>
            </DataPropertyAtom>
            <DataPropertyAtom>
