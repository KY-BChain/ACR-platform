#################################################################
#    Annotations
#################################################################

acr:hasBMI推导 rdfs:comment "身体质量指数（kg/m2）"@zh ;
             rdfs:label "BMI（推导）"@zh .


acr:hasDICOM图像访问策略 rdfs:comment "确认图像保留在医院PACS中，外部仅引用元数据/UID"@zh ;
                   rdfs:label "DICOM图像访问策略"@zh .


acr:hasER结果标志和百分比 rdfs:comment "ER阳性/阴性及百分比（如可用）"@zh ;
                  rdfs:label "ER结果（标志和百分比）"@zh .


acr:hasHER2FISH比率Or结果 rdfs:comment "FISH数值比率或扩增/未扩增"@zh ;
                      rdfs:label "HER2 FISH比率/结果"@zh .


acr:hasHER2IHC评分 rdfs:comment "IHC 0 / 1+ / 2+ / 3+"@zh ;
                 rdfs:label "HER2 IHC评分"@zh .


acr:hasHER2最终解释 rdfs:comment "HER2阳性或阴性（按指南）"@zh ;
                rdfs:label "HER2最终解释"@zh .


acr:hasHER2靶向药物和持续时间 rdfs:comment "药物名称和计划持续时间（月）"@zh ;
                     rdfs:label "HER2靶向药物和持续时间"@zh .


acr:hasKi-67增殖指数 rdfs:comment "Ki-67百分比（如报告）"@zh ;
                 rdfs:label "Ki-67增殖指数"@zh .


acr:hasMDT会议日期 rdfs:comment "讨论病例的多学科会议日期/时间"@zh ;
               rdfs:label "MDT会议日期"@zh .


acr:hasMDT参会人员角色 rdfs:comment "出席临床角色列表（外科医生；肿瘤医生；放射科医生；病理医生）"@zh ;
                 rdfs:label "MDT参会人员（角色）"@zh .


acr:hasMDT建议摘要 rdfs:comment "结构化临床建议（手术vs新辅助；辅助计划）"@zh ;
               rdfs:label "MDT建议摘要"@zh .


acr:hasPR结果标志和百分比 rdfs:comment "PR阳性/阴性及百分比（如可用）"@zh ;
                  rdfs:label "PR结果（标志和百分比）"@zh .


acr:hasSNOMED映射可用 rdfs:comment "此元素是否有SNOMED CT映射可用（是/否）"@zh ;
                  rdfs:label "SNOMED映射可用"@zh .


acr:has临床TNMcTNM rdfs:comment "临床T、N、M组分结构化（cT、cN、cM）"@zh ;
                 rdfs:label "临床TNM（cTNM）"@zh .


acr:has主诉 rdfs:comment "主要临床症状或转诊原因"@zh ;
          rdfs:label "主诉"@zh .


acr:has乳腺侧别 rdfs:comment "受影响侧：左/右/双侧"@zh ;
            rdfs:label "乳腺侧别"@zh .


acr:has产次和产科史 rdfs:comment "怀孕/生育次数及相关产科史"@zh ;
              rdfs:label "产次和产科史"@zh .


acr:has体重千克 rdfs:comment "体重（千克）"@zh ;
            rdfs:label "体重（千克）"@zh .


acr:has全身治疗开始日期 rdfs:comment "全身治疗开始日期"@zh ;
                rdfs:label "全身治疗开始日期"@zh .


acr:has内分泌治疗药物和计划持续时间 rdfs:comment "药物和持续时间（年）"@zh ;
                      rdfs:label "内分泌治疗药物和计划持续时间"@zh .


acr:has出生性别Or人口统计 rdfs:comment "患者生理性别（女/男）"@zh ;
                  rdfs:label "出生性别/人口统计"@zh .


acr:has出生日期 rdfs:comment "出生日期"@zh ;
            rdfs:label "出生日期"@zh .


acr:has切缘手术标本 rdfs:comment "切缘干净/受累/接近及距离（如可用）"@zh ;
              rdfs:label "切缘（手术标本）"@zh .


acr:has化疗计划周期和完成周期 rdfs:comment "计划周期数和实际完成周期数"@zh ;
                   rdfs:label "化疗计划周期和完成周期"@zh .


acr:has医嘱和检验元数据代码Or结果 rdfs:comment "医嘱项目代码、名称、时间戳、结果和异常标志"@zh ;
                      rdfs:label "医嘱和检验元数据（代码/结果）"@zh .


acr:has合并症列表 rdfs:comment "与肿瘤学相关的关键合并症（高血压、糖尿病、冠心病、自身免疫性疾病、甲状腺疾病）"@zh ;
             rdfs:label "合并症列表"@zh .


acr:has吸烟状况 rdfs:comment "当前/曾经/从未吸烟及吸烟年限（如吸烟）"@zh ;
            rdfs:label "吸烟状况"@zh .


acr:has基因组检测名称和数值评分 rdfs:comment "检测名称（Oncotype、MammaPrint）和数值评分"@zh ;
                    rdfs:label "基因组检测名称和数值评分"@zh .


acr:has基因组检测执行 rdfs:comment "是否执行多基因预后检测（是/否）"@zh ;
               rdfs:label "基因组检测执行"@zh .


acr:has复发或进展标志 rdfs:comment "患者是否有局部复发或远处进展"@zh ;
               rdfs:label "复发或进展标志"@zh .


acr:has复发日期和部位 rdfs:comment "复发日期和解剖部位（如存在）"@zh ;
               rdfs:label "复发日期和部位"@zh .


acr:has家族癌症史 rdfs:comment "结构化家族癌症史（关系和癌症类型）"@zh ;
             rdfs:label "家族癌症史"@zh .


acr:has就诊日期Or时间 rdfs:comment "患者首次出现症状的日期/时间"@zh ;
                rdfs:label "就诊日期/时间"@zh .


acr:has年龄推导 rdfs:comment "就诊时年龄（岁）"@zh ;
            rdfs:label "年龄（推导）"@zh .


acr:has影像发现编码 rdfs:comment "关键发现尽可能映射到SNOMED CT"@zh ;
              rdfs:label "影像发现编码"@zh .


acr:has影像报告完整发现 rdfs:comment "完整放射学报告文本"@zh ;
                rdfs:label "影像报告完整发现"@zh .


acr:has影像报告摘要 rdfs:comment "放射科医生印象简短文本"@zh ;
              rdfs:label "影像报告摘要"@zh .


acr:has影像检查日期Or时间 rdfs:comment "影像检查执行的日期和时间"@zh ;
                  rdfs:label "影像检查日期/时间"@zh .


acr:has影像检查标识符 rdfs:comment "DICOM StudyInstanceUID或本地影像ID"@zh ;
               rdfs:label "影像检查标识符"@zh .


acr:has影像模态 rdfs:comment "执行的影像类型（乳腺X线、超声、MRI、CT、PET）"@zh ;
            rdfs:label "影像模态"@zh .


acr:has影像评估BI-RADS rdfs:comment "BI-RADS或本地风险/评估类别"@zh ;
