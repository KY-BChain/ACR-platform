###  https://medical-ai.org/ontologies/ACR#CategoryI
acr:CategoryI rdf:type owl:NamedIndividual ,
                       acr:RecommendationLevel ;
              rdfs:comment "High-level evidence, uniform consensus, widely available in China"@en ;
              rdfs:label "1类推荐"@zh ,
                         "Category I"@en .


###  https://medical-ai.org/ontologies/ACR#CategoryII
acr:CategoryII rdf:type owl:NamedIndividual ,
                        acr:RecommendationLevel ;
               rdfs:comment "Lower-level evidence or cost/accessibility considerations"@en ;
               rdfs:label "2类推荐"@zh ,
                          "Category II"@en .


###  https://medical-ai.org/ontologies/ACR#CategoryIII
acr:CategoryIII rdf:type owl:NamedIndividual ,
                         acr:RecommendationLevel ;
                rdfs:comment "Evidence exists but significant cost/access limitations"@en ;
                rdfs:label "3类推荐"@zh ,
                           "Category III"@en .


